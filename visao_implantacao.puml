@startuml
title Diagrama de Implantação - Sistema VetCare

skinparam node {
    BackgroundColor White
    BorderColor Black
}

' --- Camada de Dispositivos (Clientes) ---
node "Dispositivo do Tutor" <<Smartphone>> as tutorNode {
    artifact "VetCare App (View)" <<Mobile SPA>> as tutorArtifact
}

node "Dispositivo da Clínica" <<PC / Laptop>> as vetNode {
    artifact "Portal Web (View)" <<Web SPA>> as vetArtifact
}

' --- Rede ---
cloud "Internet" as internet {
    queue "HTTPS / TLS 1.3" as https
}

' --- Infraestrutura em Nuvem ---
node "Nuvem (Cloud Provider)" as cloudNode {

    node "Load Balancer" <<Nginx / Ingress>> as lb {
        note right: Distribui tráfego e gerencia\nterminação SSL
    }

    node "Cluster de Aplicação (Docker)" as cluster {
        node "App Container 1" <<Docker>> as c1 {
            artifact "Backend API (Controller/Model)" <<JAR/Spring Boot>> as api1
        }
        node "App Container 2" <<Docker>> as c2 {
            artifact "Backend API (Controller/Model)" <<JAR/Spring Boot>> as api2
        }
        note bottom: Backend Stateless permite\nescalabilidade horizontal
    }

    node "Cluster de Banco de Dados" as dbCluster {
        node "Servidor Principal" <<PostgreSQL 16>> as dbPrimary {
            database "VetCare_DB" as sqlPrimary
        }
        node "Réplica de Leitura" <<PostgreSQL 16>> as dbReplica {
            database "VetCare_DB_Copy" as sqlReplica
        }
    }

    node "Storage & Entrega" as storageNode {
        node "Object Storage" <<S3 / similar>> as s3 {
            artifact "Mídias e Documentos" <<Blob>> as media
        }
        node "CDN" <<Edge Network>> as cdn {
            note top: Cache de vídeos/fotos\npara performance (RNF-004)
        }
    }
}

' --- Conexões e Comunicação ---
tutorNode -- https
vetNode -- https
https -- lb

lb -- cluster : "REST API (JSON)"
cluster -- dbPrimary : "JDBC / ACID"
cluster -- dbReplica : "Leitura de Relatórios"
cluster -- s3 : "Upload / Download"

cdn -- internet : "Entrega de mídias pesadas"
dbPrimary ..> dbReplica : "Replicação Síncrona"

@enduml
